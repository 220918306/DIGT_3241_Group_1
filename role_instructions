P4 — CONFIG & DISCOVERY OWNER
----------------------------------------------------------------
GOAL: Write Kubernetes manifests for config and discovery servers.

STEP 1: Create config-server deployment
  CLI:
  cat > k8s/config-server-deployment.yaml << 'EOF'
  apiVersion: apps/v1
  kind: Deployment
  metadata:
    name: config-server
    namespace: spring-petclinic
  spec:
    replicas: 1
    selector:
      matchLabels:
        app: config-server
    template:
      metadata:
        labels:
          app: config-server
      spec:
        containers:
          - name: config-server
            image: YOUR_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/petclinic/config-server:latest
            ports:
              - containerPort: 8888
            env:
              - name: SPRING_PROFILES_ACTIVE
                value: "native"
            readinessProbe:
              httpGet:
                path: /actuator/health
                port: 8888
              initialDelaySeconds: 30
              periodSeconds: 10
  ---
  apiVersion: v1
  kind: Service
  metadata:
    name: config-server
    namespace: spring-petclinic
  spec:
    selector:
      app: config-server
    ports:
      - port: 8888
        targetPort: 8888
    type: ClusterIP
  EOF

STEP 2: Create discovery-server deployment
  CLI:
  cat > k8s/discovery-server-deployment.yaml << 'EOF'
  apiVersion: apps/v1
  kind: Deployment
  metadata:
    name: discovery-server
    namespace: spring-petclinic
  spec:
    replicas: 1
    selector:
      matchLabels:
        app: discovery-server
    template:
      metadata:
        labels:
          app: discovery-server
      spec:
        containers:
          - name: discovery-server
            image: YOUR_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/petclinic/discovery-server:latest
            ports:
              - containerPort: 8761
            env:
              - name: SPRING_PROFILES_ACTIVE
                value: "docker"
            readinessProbe:
              httpGet:
                path: /actuator/health
                port: 8761
              initialDelaySeconds: 30
              periodSeconds: 10
  ---
  apiVersion: v1
  kind: Service
  metadata:
    name: discovery-server
    namespace: spring-petclinic
  spec:
    selector:
      app: discovery-server
    ports:
      - port: 8761
        targetPort: 8761
    type: ClusterIP
  EOF

STEP 3: Commit manifests
  CLI:
  git add k8s/
  git commit -m "feat(p4): add config and discovery server K8s manifests"
  git push origin main

